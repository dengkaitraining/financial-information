# ==============================================================================
# MariaDB 資料庫 使用者自定義設定檔 (my_custom.cnf)
# 說明：配置字元集、排序規則、高併發連線池與 InnoDB 記憶體優化選項
# ==============================================================================

[mysqld]
# ------------------------------------------------------------------------------
# 1. 預設字元集與排序規則 (Character Set & Collation)
# ------------------------------------------------------------------------------
# 設定預設字元集為 utf8mb4 (支援完整 Unicode Emoji 符號)
character-set-server = utf8mb4
# 設定預設校對規則為 utf8mb4_unicode_ci (大小寫不敏感)
collation-server = utf8mb4_unicode_ci



# ------------------------------------------------------------------------------
# 2. 連線池與記憶體管理 (Connections & Buffer Pool Tuning)
# ------------------------------------------------------------------------------
# 提高最大允許同時連線數至 250，避免併發存取時出現 Too many connections 錯誤
max_connections = 250

# 預設資料表儲存引擎設定為 InnoDB
default_storage_engine = InnoDB

# 設定 InnoDB 緩衝區池大小為 256MB，提升資料快取讀寫效能
innodb_buffer_pool_size = 256M

# 設定 InnoDB 重做日誌檔大小為 64MB
innodb_log_file_size = 64M

# ------------------------------------------------------------------------------
# 3. 慢查詢紀錄 (Slow Query Log Options)
# ------------------------------------------------------------------------------
# 開啟慢查詢日誌紀錄
slow_query_log = 1

# 慢查詢日誌檔輸出路徑
slow_query_log_file = /var/lib/mysql/slow-query.log

# 觸發慢查詢日誌的時間閾值 (秒)
long_query_time = 2

# ------------------------------------------------------------------------------
# 4. 宿主機檔案系統實體目錄掛載相容性設定 (Host Volume Compatibility)
# ------------------------------------------------------------------------------
# 停用獨立 .ibd 表空間 (改用共享系統表空間 ibdata1)，徹底解決 Windows NTFS 宿主機實體目錄掛載時 .ibd 檔案鎖定與 tablespace errno 194 錯誤
innodb_file_per_table = 0
innodb_use_native_aio = 0
innodb_flush_method = O_DSYNC
innodb_flush_log_at_trx_commit = 2



