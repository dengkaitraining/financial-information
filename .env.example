# ==============================================================================
# Django + Vue.js 開發環境全局變數設定檔 (.env)
# 說明：包含資料庫憑證、Redis 參數、Django Secret Key 與使用者自定義設定檔路徑
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. 網頁伺服器、資料庫與快取 使用者自定義 (User-Defined) 設定檔路徑
# ------------------------------------------------------------------------------
# Apache HTTPD 反向代理自定義設定檔路徑
APACHE_CUSTOM_CONF=./apache/httpd-custom.conf

# MariaDB 資料庫自定義設定檔路徑
MARIADB_CUSTOM_CONF=./db_conf/my_custom.cnf

# Redis 快取伺服器自定義設定檔路徑
REDIS_CUSTOM_CONF=./redis_conf/redis.conf

# ------------------------------------------------------------------------------
# 2. MariaDB 資料庫連線與帳密設定
# ------------------------------------------------------------------------------
# 主要資料庫 (user_stock_db / user_stock 帳號)
DB_NAME=django_db
DB_USER=django_user
DB_PASSWORD=user_stock_pass
DB_ROOT_PASSWORD=db_root_secure_pass
DB_HOST=db
DB_PORT=3306

# 員工資料庫 (db_employee / user_employee 帳號)
EMPLOYEE_DB_NAME=db_employee
EMPLOYEE_DB_USER=user_employee
EMPLOYEE_DB_PASSWORD=user_employee_pass

# ------------------------------------------------------------------------------
# 3. Redis 快取與 Session 連線設定
# ------------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# ------------------------------------------------------------------------------
# 4. Django 後端應用程式設定
# ------------------------------------------------------------------------------
# Django 安全金鑰
DJANGO_SECRET_KEY=django-insecure-3h#r4e1(d7s_9k&m0s!v@z^6p*p=w+r*y_u6h7j5x9b3c)n1v2
# 開發模式除錯開關 (True/False)
DJANGO_DEBUG=True
# 允許造訪的主機名稱
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web,backend,fin-backend
# 顯示後端手動測試驗證資料的開關 (True: 測試開發環境顯示 / False: 正式上線隱蔽)
SHOW_BACKEND_VER=True

# 顯示前端手動測試驗證資料的開關 (True: 測試開發環境顯示 / False: 正式上線隱蔽)
SHOW_FRONTEND_VER=True

# ------------------------------------------------------------------------------
# 5. Django Unfold 後台超級管理員預設憑證 (自動初始化帳號)
# ------------------------------------------------------------------------------
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=adminpassword123

# ------------------------------------------------------------------------------
# 6. 宿主機 (Host) 埠號對應
# ------------------------------------------------------------------------------
HOST_WEB_PORT=80
HOST_DB_PORT=3306
HOST_REDIS_PORT=6379
